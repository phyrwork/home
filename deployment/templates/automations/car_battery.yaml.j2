{% raw %}
- id: car_battery_sync_percent_to_energy
  alias: Car Battery Sync Percent To Energy
  description: Keep kWh helpers in sync when % or capacity changes
  trigger:
    - platform: state
      entity_id:
        - sensor.car_battery_level
        - input_number.car_battery_level_target
        - input_number.car_battery_energy_capacity
  action:
    - variables:
        capacity: "{{ states('input_number.car_battery_energy_capacity') | float(0) }}"
        level_current: "{{ states('sensor.car_battery_level') | float(0) }}"
        level_target: "{{ states('input_number.car_battery_level_target') | float(0) }}"
        energy_target: "{{ (capacity * level_target / 100) | round(3) }}"
    - service: input_number.set_value
      target:
        entity_id: input_number.car_battery_energy_target
      data:
        value: "{{ energy_target }}"
  mode: single

- id: car_battery_sync_soc_target_to_intelligent_delta
  alias: Car Battery Sync SOC Target To Intelligent Delta
  description: >-
    Update Octopus Intelligent charge delta from SOC target. For Octopus Charge
    this entity behaves as delta-to-add rather than absolute SOC target.
  trigger:
    - platform: state
      entity_id:
        - input_number.car_battery_level_target
        - sensor.car_battery_level
        - binary_sensor.octopus_energy_{% endraw %}{{ ev_charger_device_id }}{% raw %}_intelligent_dispatching
    - platform: homeassistant
      event: start
    - platform: time_pattern
      minutes: "/5"
  action:
    - variables:
        applied_delta_entity_id: "number.octopus_energy_{% endraw %}{{ ev_charger_device_id }}{% raw %}_intelligent_charge_target"
        dispatching_entity_id: "binary_sensor.octopus_energy_{% endraw %}{{ ev_charger_device_id }}{% raw %}_intelligent_dispatching"
        smart_charge_switch_entity_id: "switch.octopus_energy_{% endraw %}{{ ev_charger_device_id }}{% raw %}_intelligent_smart_charge"
        target_level: "{{ states('input_number.car_battery_level_target') | float(0) }}"
        current_level: "{{ states('sensor.car_battery_level') | float(0) }}"
        target_delta_required: "{{ [target_level - current_level, 0] | max | round(0) | int }}"
        # Octopus target accepts 10-100. Guarantee some progress for non-zero deltas.
        target_delta_requested: >-
          {% if target_delta_required <= 0 %}
            0
          {% elif target_delta_required < 10 %}
            10
          {% else %}
            {{ [target_delta_required, 100] | min }}
          {% endif %}
        target_delta_applied: "{{ states(applied_delta_entity_id) | int(-1) }}"
        last_increase_update_at_raw: "{{ states('input_datetime.car_battery_intelligent_target_last_increase_update') }}"
        planned_dispatches_raw: "{{ state_attr(dispatching_entity_id, 'planned_dispatches') }}"
        planned_dispatches: >-
          {% if planned_dispatches_raw is string %}
            {% if planned_dispatches_raw in ['unknown', 'unavailable', 'none', ''] %}
              []
            {% else %}
              {{ planned_dispatches_raw | from_json }}
            {% endif %}
          {% else %}
            {{ planned_dispatches_raw | default([], true) }}
          {% endif %}
        started_dispatches_raw: "{{ state_attr(dispatching_entity_id, 'started_dispatches') }}"
        started_dispatches: >-
          {% if started_dispatches_raw is string %}
            {% if started_dispatches_raw in ['unknown', 'unavailable', 'none', ''] %}
              []
            {% else %}
              {{ started_dispatches_raw | from_json }}
            {% endif %}
          {% else %}
            {{ started_dispatches_raw | default([], true) }}
          {% endif %}
        dispatch_attributes_available: >-
          {{
            planned_dispatches_raw not in [none, 'unknown', 'unavailable', 'none', '']
            and started_dispatches_raw not in [none, 'unknown', 'unavailable', 'none', '']
          }}
        dispatches: >-
          {{ planned_dispatches + started_dispatches }}
        dispatch_start_times: >-
          {{ dispatches | map(attribute='start') | list }}
        dispatch_end_times: >-
          {{ dispatches | map(attribute='end') | list }}
        earliest_dispatch_start: >-
          {% if dispatch_start_times %}
            {{ as_datetime(dispatch_start_times | min).isoformat() }}
          {% else %}
            {{ none }}
          {% endif %}
        latest_dispatch_end: >-
          {% if dispatch_end_times %}
            {{ as_datetime(dispatch_end_times | max).isoformat() }}
          {% else %}
            {{ none }}
          {% endif %}
        is_increase: "{{ target_delta_requested > target_delta_applied }}"
        is_decrease: "{{ target_delta_requested < target_delta_applied }}"
        smart_charge_on: "{{ is_state(smart_charge_switch_entity_id, 'on') }}"
        # Increases are safe to allow (with rate limiting): they usually come from
        # an explicit user target increase or a reported SOC drop, where rescheduling
        # is acceptable.
        should_allow_increase: >-
          {% if not is_increase %}
            false
          {% elif last_increase_update_at_raw in [none, 'unknown', 'unavailable', 'none', ''] %}
            true
          {% else %}
            {{ (as_timestamp(now()) - as_timestamp(as_datetime(last_increase_update_at_raw))) >= 15 * 60 }}
          {% endif %}
        # Avoid decreases during an announced dispatch schedule window to reduce the
        # risk of disrupting or resetting the active intelligent schedule.
        should_allow_decrease: >-
          {% if not is_decrease %}
            false
          {% elif not dispatch_attributes_available %}
            false
          {% elif dispatches | count == 0 %}
            true
          {% else %}
            {% set first_start = as_datetime(earliest_dispatch_start) if earliest_dispatch_start not in [none, 'unknown', 'unavailable', 'none', ''] else none %}
            {% set last_end = as_datetime(latest_dispatch_end) if latest_dispatch_end not in [none, 'unknown', 'unavailable', 'none', ''] else none %}
            {% if first_start and last_end %}
              {{ now() < first_start or now() > last_end }}
            {% else %}
              false
            {% endif %}
          {% endif %}
        should_disable_smart_charge: "{{ target_delta_requested <= 0 and smart_charge_on }}"
        should_apply_target_update: >-
          {{
            target_delta_applied >= 0
            and target_delta_requested > 0
            and target_delta_requested != target_delta_applied
            and (
              (is_increase and should_allow_increase)
              or (is_decrease and should_allow_decrease)
            )
          }}
    - choose:
        - conditions:
            - condition: template
              value_template: "{{ should_disable_smart_charge }}"
          sequence:
            - service: switch.turn_off
              target:
                entity_id: "{{ smart_charge_switch_entity_id }}"
        - conditions:
            - condition: template
              value_template: "{{ should_apply_target_update }}"
          sequence:
            - choose:
                - conditions:
                    - condition: template
                      value_template: "{{ not smart_charge_on }}"
                  sequence:
                    - service: switch.turn_on
                      target:
                        entity_id: "{{ smart_charge_switch_entity_id }}"
            - service: number.set_value
              target:
                entity_id: number.octopus_energy_{% endraw %}{{ ev_charger_device_id }}{% raw %}_intelligent_charge_target
              data:
                value: "{{ target_delta_requested }}"
            - choose:
                - conditions:
                    - condition: template
                      value_template: "{{ is_increase }}"
                  sequence:
                    - service: input_datetime.set_datetime
                      target:
                        entity_id: input_datetime.car_battery_intelligent_target_last_increase_update
                      data:
                        datetime: "{{ now().strftime('%Y-%m-%d %H:%M:%S') }}"
  mode: restart

- id: car_battery_stop_charge_at_target
  alias: Car Battery Stop Charge At Target
  description: Stop the charger when target energy is reached
  trigger:
    - platform: state
      entity_id:
        - sensor.car_battery_energy_current
        - input_number.car_battery_energy_target
  condition:
    - condition: template
      value_template: >-
        {% set current = states('sensor.car_battery_energy_current') | float(0) %}
        {% set target = states('input_number.car_battery_energy_target') | float(0) %}
        {{ current >= target }}
  action:
    - service: homeassistant.turn_off
      target:
        entity_id: switch.ev_charger
  mode: single

- id: car_battery_start_charge_at_best_time
  alias: Car Battery Start Charge At Best Time
  description: Start the EV charger at the cheapest start time
  trigger:
    - platform: state
      entity_id: sensor.car_battery_target_cost_next_lowest_start_cost_time
    - platform: time_pattern
      minutes: "/1"
  condition:
    - condition: state
      entity_id: switch.ev_charger
      state: "off"
    - condition: template
      value_template: >-
        {% set needed = states('sensor.car_battery_energy_needed') | float(0) %}
        {{ needed > 0 }}
    # Avoid daytime starts unless tomorrow's rates are published; Octopus releases them ~16:00.
    - condition: template
      value_template: >-
        {% set now_local = now() %}
        {% if now_local.hour >= 8 and now_local.hour < 17 %}
          {% set rates_raw = state_attr('sensor.octopus_energy_electricity_21l4421345_2700007165105_fused_day_rates', 'rates') %}
          {% if rates_raw is string %}
            {% set rates = rates_raw | from_json %}
          {% else %}
            {% set rates = rates_raw | default([], true) %}
          {% endif %}
          {% set ends = rates | map(attribute='end') | list %}
          {% set latest_end = ends | max if ends else none %}
          {% if latest_end %}
            {{ as_datetime(latest_end).date() > now_local.date() }}
          {% else %}
            false
          {% endif %}
        {% else %}
          true
        {% endif %}
    - condition: template
      value_template: >-
        {% set start_time = states('sensor.car_battery_target_cost_next_lowest_start_cost_time') %}
        {% if start_time in ['unknown', 'unavailable', 'none', ''] %}
          false
        {% else %}
          {{ now() >= as_datetime(start_time) }}
        {% endif %}
  action:
    - service: homeassistant.turn_on
      target:
        entity_id: switch.ev_charger
  mode: single

# Fallback: ensure we still use the 23:30-05:30 off-peak window even if the
# scheduler can't find a valid start time for the defined window.
- id: car_battery_start_charge_fallback_off_peak
  alias: Car Battery Start Charge Fallback Off Peak
  description: Start charging at 23:30 if no next start time is available
  trigger:
    - platform: time
      at: "23:30:00"
  condition:
    - condition: state
      entity_id: switch.ev_charger
      state: "off"
    - condition: template
      value_template: >-
        {% set needed = states('sensor.car_battery_energy_needed') | float(0) %}
        {{ needed > 0 }}
    - condition: template
      value_template: >-
        {% set start_time = states('sensor.car_battery_target_cost_next_lowest_start_cost_time') %}
        {{ start_time in ['unknown', 'unavailable', 'none', ''] }}
  action:
    - service: homeassistant.turn_on
      target:
        entity_id: switch.ev_charger
  mode: single

- id: car_battery_stop_charge_at_off_peak_end
  alias: Car Battery Stop Charge At Off Peak End
  description: Stop charging at 05:30 even if target is not reached
  trigger:
    - platform: time
      at: "05:30:00"
  condition:
    - condition: state
      entity_id: switch.ev_charger
      state: "on"
  action:
    - service: homeassistant.turn_off
      target:
        entity_id: switch.ev_charger
  mode: single
{% endraw %}
