{% for device in battery_devices %}
{% set sensor_name = device.name ~ ' Battery Low' %}
{% set sensor_slug = sensor_name | slugify %}
{% set sensor_entity_id = 'binary_sensor.' ~ sensor_slug %}
{% set alert_id = sensor_slug %}
{{ alert_id }}:
  name: {{ device.name }} battery is low or unavailable
  message: >-
    {% raw %}{% set state = states('{% endraw %}{{ device.entity_id }}{% raw %}') | lower %}
    {% if state in ['unavailable', 'unknown', 'none'] %}
      The {{ device.name }} battery status is unavailable.
    {% else %}
      The {{ device.name }} battery is low ({{ state }}%).
    {% endif %}{% endraw %}
  done_message: >-
    {% raw %}The {{ device.name }} battery is OK ({{ states('{% endraw %}{{ device.entity_id }}{% raw %}') }}%).{% endraw %}
  entity_id: {{ sensor_entity_id }}

  # Ignore for 60m, then repeat every 24h
  repeat:
    - 60
    - 1440
  skip_first: true

  # Create a notification in Home Assistant
  notifiers:
    - persistent_notification
    - all_phones
  data:
    notification_id: {{ alert_id }}

{% endfor %}
